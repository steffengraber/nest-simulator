#!/bin/sh

# Make PyNEST available by prepending its path to PYTHONPATH in a safe way.
export PYTHONPATH="$( python3 -c 'import site; print(site.USER_SITE)' )${PYTHONPATH:+:$PYTHONPATH}"

# Make NEST executables available by prepending their path to PATH.
export PATH="$( python3 -c  'import site; print(site.USER_SITE)' )/bin:${PATH}"


